{
  "name": "wander",
  "version": "1.0.0",
  "description": "A desktop travel planning app built with Electron + Next.js, powered by a Supabase Postgres backend and a dbt Core data pipeline. Plan trips on a date-based kanban board with live weather, currency conversion, and destination insights. Built as a data engineering portfolio showcase.",
  "main": "dist-electron/main.js",
  "scripts": {
    "dev:next": "next dev",
    "dev:electron": "wait-on http://localhost:3000 && cross-env NODE_ENV=development electron .",
    "dev": "concurrently \"npm run dev:next\" \"npm run dev:electron\"",
    "build:next": "next build",
    "build:electron": "tsc -p tsconfig.electron.json",
    "build": "npm run build:next && npm run build:electron",
    "package": "npm run build && electron-builder"
  },
  "build": {
    "appId": "com.wander.app",
    "productName": "Wander",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist-electron/**/*",
      "out/**/*"
    ],
    "win": {
      "target": "nsis"
    },
    "mac": {
      "target": "dmg"
    }
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/leonardpoon/wander.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/leonardpoon/wander/issues"
  },
  "homepage": "https://github.com/leonardpoon/wander#readme",
  "dependencies": {
    "@supabase/supabase-js": "^2.107.0",
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^25.9.1",
    "@types/react": "^19.2.16",
    "autoprefixer": "^10.5.0",
    "bcryptjs": "^3.0.3",
    "concurrently": "^10.0.3",
    "cross-env": "^10.1.0",
    "electron": "^42.3.3",
    "electron-builder": "^26.8.1",
    "electron-store": "^11.0.2",
    "next": "^14.2.35",
    "postcss": "^8.5.15",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "tailwindcss": "^3.4.0",
    "typescript": "^5.4.5",
    "wait-on": "^9.0.10",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@types/electron": "^1.4.38",
    "ts-node": "^10.9.2"
  }
}