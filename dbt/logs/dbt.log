  create  table "postgres"."mart"."mart_fx_rates__dbt_tmp"
  
  
    as
  
  (
    -- US-44

with scd as (
    select * from "postgres"."intermediate"."int_fx_scd"
),

final as (
    select
        base_currency,
        target_currency,
        rate,
        valid_from,
